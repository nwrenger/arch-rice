[Trigger]
Operation = Upgrade
Type = Package
Target = hyprutils

[Action]
Description = Notifying about hyprshutdown rebuild...
When = PostTransaction
Exec = /usr/bin/sudo -u nils DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus /usr/bin/notify-send -u critical "pacman" "hyprshutdown needs a rebuild, run fix-hyprshutdown"
