#!/usr/bin/env fish

set s (mullvad status)

if string match -q "*Connected*" $s || string match -q "*Connecting*" $s
    mullvad disconnect
    swayosd-client --custom-message "VPN Disconnecting..." --custom-icon network-offline
else
    mullvad connect
    swayosd-client --custom-message "VPN Connecting..." --custom-icon network-transmit-receive
end

pkill -RTMIN+2 waybar
