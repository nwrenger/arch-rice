#!/usr/bin/env fish

# Toggle microphone mute and show OSD notification.
# By default mapped to XF86AudioMicMute.

wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

set muted  (wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -c MUTED)
set monitor (hyprctl monitors -j | jq -r '.[] | select(.focused == true).name')

brightnessctl --device="platform::micmute" set "$muted" 2>/dev/null; or true

set icon  (test "$muted" = "1"; and echo muted;  or echo high)
set label (test "$muted" = "1"; and echo muted;  or echo active)

swayosd-client \
    --monitor      "$monitor" \
    --custom-icon  "microphone-sensitivity-$icon-symbolic" \
    --custom-message "Mic $label"

pkill -RTMIN+1 waybar
