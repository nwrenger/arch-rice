#!/usr/bin/env fish

set options "¾░Éź Shutdown" "¾░£ē Reboot" "¾░Źā Logout" "¾░żä Suspend"
set choice (printf "%s\n" $options | walker --dmenu --nosearch --minwidth 200 --minheight 150)

switch $choice
    case "¾░Éź Shutdown"
        hyprshutdown -t 'Shutting down...' --post-cmd 'shutdown -P 0'
        or shutdown -P 0
    case "¾░£ē Reboot"
        hyprshutdown -t 'Restarting...' --post-cmd 'reboot'
        or reboot
    case "¾░Źā Logout"
        hyprshutdown -t 'Logging out...'
        or hyprctl dispatch exit
    case "¾░żä Suspend"
        systemctl suspend
    case ""
        if not contains -- nomenu $argv
            menu
        else
            walker --close
        end
end
