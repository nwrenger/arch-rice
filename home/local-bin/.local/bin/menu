#!/usr/bin/env fish
source ~/.local/bin/menu-lib

set options "ůįčľ About" "ůįŹó Install" "ůįöį Update" "ůįÜī Remove" "ůįź• Power"
set choice (printf "%s\n" $options | walker --dmenu --nosearch --minwidth 250 --minheight 250)

switch $choice
    case "ůįčľ About"
        alacritty --title "fastfetch" -e fish -c "
            source ~/.local/bin/menu-lib
            fastfetch
            show_done"
    case "ůįŹó Install"
        menu-install
    case "ůįöį Update"
        alacritty --title "walker menu" -e fish -c "
            source ~/.local/bin/menu-lib
            menu-update
            show_done"
    case "ůįÜī Remove"
        menu-remove
    case "ůįź• Power"
        menu-power
end
